{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "city-match-ai",
  "main": "src/index.js",
  "compatibility_date": "2024-03-09",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  },
  "routes": [
    {
      "pattern": "city.io99.xyz",
      "custom_domain": true
    }
  ],
  "observability": {
    "enabled": true
  }
}
